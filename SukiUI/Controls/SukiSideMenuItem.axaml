<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:content="clr-namespace:SukiUI.Content"
                    xmlns:converters="https://github.com/kikipoulet/SukiUI"
                    xmlns:suki="clr-namespace:SukiUI.Controls">
    <Design.PreviewWith>
        <suki:SukiSideMenu>
            <suki:SukiSideMenuItem Header="Header">
                <suki:SukiSideMenuItem.Icon>
                    <PathIcon Width="13"
                              Height="13"
                              Data="{x:Static content:Icons.Cross}" />
                </suki:SukiSideMenuItem.Icon>

            </suki:SukiSideMenuItem>
            <suki:SukiSideMenuItem Header="Header">
                <suki:SukiSideMenuItem.Icon>
                    <PathIcon Width="13"
                              Height="13"
                              Data="{x:Static content:Icons.Cross}" />
                </suki:SukiSideMenuItem.Icon>
                <Grid />
            </suki:SukiSideMenuItem>
        </suki:SukiSideMenu>
    </Design.PreviewWith>
    <ControlTheme x:Key="SukiSideMenuItemStyle" TargetType="suki:SukiSideMenuItem">
        <Setter Property="Template">
            <ControlTemplate>
                <DockPanel>
                    <!-- Children panel: visibility driven by the expander's own IsExpanded
                         alone, NOT by the sidebar's IsMenuExpanded. That way an expanded
                         group keeps showing its children in the icon-rail mode (as
                         icon-only rows), and a collapsed group hides its children in both
                         sidebar modes. A Style further down zeroes the indent in icon-rail
                         mode so child icons align with the rail. -->
                    <Panel DockPanel.Dock="Bottom">
                        <ItemsPresenter Name="PART_ItemsPresenter"
                                        Margin="20,0,0,0"
                                        IsVisible="{TemplateBinding IsExpanded}"
                                        ItemsPanel="{TemplateBinding ItemsPanel}" />
                    </Panel>
                    <Border Name="PART_Border"
                            MinWidth="85"
                            Margin="{DynamicResource SukiSideMenuItemMargin}"
                            Padding="{DynamicResource SukiSideMenuItemPadding}"
                            Background="{DynamicResource SukiPrimaryColor0}"
                            CornerRadius="{DynamicResource MediumCornerRadius}">
                        <Panel>
                            <Border Name="PART_ItemHighlight"
                                    Margin="-30,-15,-15,-15"
                                    CornerRadius="12"
                                    Background="Transparent" />
                            <DockPanel Name="PART_NormalDisplay" LastChildFill="True">
                                <DockPanel.Resources />
                                <DockPanel.Styles>
                                    <Style Selector="ToggleButton[IsChecked=True]">
                                        <Setter Property="RenderTransform" Value="rotate(-180deg)" />
                                    </Style>
                                </DockPanel.Styles>
                                <ToggleButton Name="PART_ExpandedButton"
                                              Margin="0,0,-8,0"
                                              HorizontalContentAlignment="Center"
                                              VerticalContentAlignment="Center"
                                              Classes="CircleGlass"
                                              DockPanel.Dock="Right"
                                              Focusable="False"
                                              IsChecked="{TemplateBinding IsExpanded, Mode=TwoWay}"
                                              IsVisible="{TemplateBinding ItemCount}">
                                    <ToggleButton.Transitions>
                                        <Transitions>
                                            <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.3" />
                                        </Transitions>
                                    </ToggleButton.Transitions>
                                    <PathIcon Width="10"
                                              Height="10"
                                              Margin="0,2,0,0"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Data="{x:Static content:Icons.ChevronDown}"
                                              Foreground="{DynamicResource SukiLowText}" />

                                </ToggleButton>

                                <ContentControl Name="PART_Icon"
                                                Width="{DynamicResource SukiSideMenuItemIconSize}"
                                                Height="{DynamicResource SukiSideMenuItemIconSize}"
                                                Content="{TemplateBinding Icon}"
                                                DockPanel.Dock="Left"
                                                RenderTransformOrigin="50%,50%">
                                    <ContentControl.Transitions>
                                        <Transitions>
                                            <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.2" />
                                            <DoubleTransition Property="Opacity" Duration="0:0:0.2" />
                                        </Transitions>
                                    </ContentControl.Transitions>
                                </ContentControl>
                                <Grid Name="PART_SideDisplay"
                                      DockPanel.Dock="Right"
                                      IsVisible="{Binding IsMenuExpanded, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type suki:SukiSideMenu}}}">
                                    <ContentPresenter Name="PART_SideDisplayContent"
                                                      Content="{Binding}"
                                                      ContentTemplate="{TemplateBinding SideDisplayTemplate}"
                                                      Margin="5,0"
                                                      IsVisible="{Binding SideDisplayTemplate, RelativeSource={RelativeSource TemplatedParent}, Converter={x:Static ObjectConverters.IsNotNull}}" />
                                </Grid>
                                <Viewbox HorizontalAlignment="Left" StretchDirection="DownOnly">
                                    <TextBlock Name="PART_Header"
                                               Margin="15,0"
                                               VerticalAlignment="Center"
                                               FontSize="{TemplateBinding FontSize}"
                                               IsVisible="{Binding IsMenuExpanded, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type suki:SukiSideMenu}}}"
                                               Text="{TemplateBinding Header}" />
                                </Viewbox>
                            </DockPanel>
                            <!-- <ContentPresenter Name="PART_AltDisplay"
                                          Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}" />-->


                        </Panel>
                    </Border>

                </DockPanel>
            </ControlTemplate>
        </Setter>

        <Style Selector="^ /template/ Border#PART_Border">
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="MaxHeight" Duration="0:0:1">
                        <DoubleTransition.Easing>CubicEaseInOut</DoubleTransition.Easing>
                    </DoubleTransition>
                    <BrushTransition Property="Background" Duration="0:0:0.35" />
                    <ThicknessTransition Property="Padding" Duration="0:0:0.35">
                        <ThicknessTransition.Easing>CubicEaseInOut</ThicknessTransition.Easing>
                    </ThicknessTransition>
                </Transitions>
            </Setter>
        </Style>

        <!-- Individual item pill — base setup (ungrouped items: stays transparent) -->
        <Style Selector="^ /template/ Border#PART_ItemHighlight">
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.25" />
                </Transitions>
            </Setter>
        </Style>
        <!-- Compact mode: counteract compact padding (30,10,15,10) -->
        <Style Selector="^.Compact /template/ Border#PART_ItemHighlight">
            <Setter Property="Margin" Value="-30,-10,-15,-10" />
        </Style>

        <Style Selector="^[IsTopMenuExpanded=False] /template/ ToggleButton#PART_ExpandedButton">
            <Setter Property="IsVisible" Value="False" />
        </Style>

        <!-- Icon-rail: zero indent on the nested children so they align with the rail. -->
        <Style Selector="^[IsTopMenuExpanded=False] /template/ ItemsPresenter#PART_ItemsPresenter">
            <Setter Property="Margin" Value="0" />
        </Style>

        <!-- Expander rows use their own icon as the chevron, so the secondary
             PART_ExpandedButton chevron would be visual noise. Hide it. -->
        <Style Selector="^[IsExpander=True] /template/ ToggleButton#PART_ExpandedButton">
            <Setter Property="IsVisible" Value="False" />
        </Style>

        <!-- Chevron-as-icon: rotate the main icon 90deg clockwise when expanded.
             Combined with a ChevronRight icon on the data side this produces
             ChevronRight (collapsed) -> ChevronDown (expanded) with a smooth
             200ms transition from the existing TransformOperationsTransition
             on PART_Icon. -->
        <Style Selector="^[IsExpander=True][IsExpanded=True] /template/ ContentControl#PART_Icon">
            <Setter Property="RenderTransform" Value="rotate(90deg)" />
        </Style>

        <Style Selector="^.Compact /template/ Border#PART_Border">
            <Setter Property="Padding" Value="30,10,15,10" />
            <Setter Property="CornerRadius" Value="12" />
        </Style>
        <Style Selector="^:pointerover">
            <Style Selector="^ /template/ Border#PART_Border">
                <Setter Property="Background" Value="{DynamicResource SukiPrimaryColor5}" />
                <Setter Property="Cursor" Value="Hand" />
            </Style>
        </Style>
        <Style Selector="^[IsSelected=True]">
            <Style Selector="^ /template/ Border#PART_Border">
                <Setter Property="Background" Value="{DynamicResource SukiPrimaryColor10}" />
            </Style>
            <Style Selector="^ /template/ TextBlock#PART_Header">
                <Setter Property="FontWeight" Value="Bold" />
                <Setter Property="Foreground" Value="{DynamicResource SukiPrimaryColor120}" />
            </Style>
            <Style Selector="^[IsContentMovable=True]">
                <Style Selector="^[IsTopMenuExpanded=True] /template/ Border#PART_Border">
                    <Setter Property="Padding" Value="-10,15,15,15" />
                </Style>
                <Style Selector="^.Compact[IsTopMenuExpanded=True] /template/ Border#PART_Border">
                    <Setter Property="Padding" Value="-10,10,15,10" />
                </Style>
                <Style Selector="^[IsTopMenuExpanded=True] /template/ ContentControl#PART_Icon">
                    <Setter Property="Opacity" Value="0" />
                </Style>

                <Style Selector="^[IsTopMenuExpanded=False] /template/ ContentControl#PART_Icon">
                    <Setter Property="Foreground" Value="{DynamicResource SukiPrimaryColor}" />
                    <Setter Property="RenderTransform">
                        <ScaleTransform ScaleX="1.12" ScaleY="1.12" />
                    </Setter>
                </Style>
            </Style>
            <Style Selector="^[IsContentMovable=False]">
                <Style Selector="^ /template/ ContentControl#PART_Icon">
                    <Setter Property="Foreground" Value="{DynamicResource SukiPrimaryColor}" />
                </Style>
            </Style>
        </Style>
        <Setter Property="FontSize" Value="{DynamicResource SukiFontSizeLarge}" />
    </ControlTheme>
    <ControlTheme x:Key="{x:Type suki:SukiSideMenuItem}"
                  BasedOn="{StaticResource SukiSideMenuItemStyle}"
                  TargetType="suki:SukiSideMenuItem" />
</ResourceDictionary>
